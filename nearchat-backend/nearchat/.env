# NearChat — Environment Variables
# Copy this to .env and fill in your values

# Server port (default: 3001)
PORT=3001

# JWT signing secret — CHANGE THIS in production to a long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=nearchat_dev_secret_change_in_production

# Frontend origin for CORS (the URL where index.html is served)
CLIENT_ORIGIN=http://localhost:3000
